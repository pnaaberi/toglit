# =============================================================================
# In-house TUI menu with live help area
#
# whiptail has no per-item help text. `dialog --item-help` would, but dialog is
# not installed on stock SteamOS and adding it requires disabling the read-only
# filesystem — exactly the kind of "extra shit" we want to avoid.
#
# So: render our own menu. Reserved 3-line help area below the list. Arrow keys
# (+ j/k) navigate, number keys jump, Enter/Space confirm, Esc/Backspace cancel.
# Help text area is always 3 lines tall — layout never shifts as the highlight
# moves.
#
# Section headers: a label prefixed with "@header:TEXT" renders as a dim
# dashed separator with TEXT inline, and is skipped during navigation. Its
# paired "help" argument is ignored (pass "").
#
# Usage: tui_menu "TITLE" "SUBTITLE" LABEL1 HELP1 LABEL2 HELP2 ...
#   On select, $REPLY = the numeric prefix on the chosen label (e.g. "1  Touch
#   Mode" → REPLY=1). Cancel returns 1.
# =============================================================================

# Word-wrap stdin to $1 columns, producing one line per output line.
# Words longer than $1 are hard-broken at the column boundary so the TUI
# box never overflows on a pathological help string.
_tui_wrap() {
    local width="$1"
    awk -v w="$width" '
        {
            for (i=1; i<=NF; i++) {
                word = $i
                while (length(word) > w) {
                    if (length(line) > 0) { print line; line = "" }
                    print substr(word, 1, w)
                    word = substr(word, w + 1)
                }
                if (length(line) == 0) {
                    line = word
                } else if (length(line) + 1 + length(word) <= w) {
                    line = line " " word
                } else {
                    print line
                    line = word
                }
            }
        }
        END { if (length(line)) print line }
    '
}

tui_menu() {
    local title="$1" subtitle="$2"
    shift 2

    local labels=() helps=()
    while (( $# >= 2 )); do
        labels+=("$1")
        helps+=("$2")
        shift 2
    done

    local n=${#labels[@]}
    local width=62
    local inner=$((width - 4))     # text cell inside "│  ...  │"
    local help_h=3                 # reserved help lines — fixed, no layout shift

    # Build a map of selectable indices (skips @header: rows).
    local items=()
    local i
    for ((i = 0; i < n; i++)); do
        [[ "${labels[i]}" != "@header:"* ]] && items+=("$i")
    done
    local item_count=${#items[@]}
    (( item_count == 0 )) && return 1

    local sel_pos=0            # cursor position within items[]
    local sel=${items[0]}      # corresponding index in labels[]

    # Colors — cyan/black to match whiptail's Breeze Dark theme
    local C_RST=$'\e[0m'
    local C_BOX=$'\e[36m'            # cyan borders
    local C_TITLE=$'\e[1;30;46m'     # bold black on cyan
    local C_SUB=$'\e[2;37m'          # dim white
    local C_SEL=$'\e[30;46m'         # black on cyan (highlight)
    local C_ITEM=$'\e[97m'           # bright white
    local C_HELP=$'\e[36m'           # cyan help text
    local C_HINT=$'\e[2;37m'         # dim hint

    local bar; bar="$(printf '─%.0s' $(seq 1 $((width - 2))))"

    # Pad $1 with spaces on the right to CHARACTER width $2. Bash's ${#s}
    # counts characters when LC_ALL is UTF-8, so em-dashes/middle-dots/box
    # glyphs align correctly.
    _pad() {
        local s="$1" w="$2"
        local len=${#s}
        if (( len >= w )); then
            printf '%s' "$s"
        else
            printf '%s%*s' "$s" "$((w - len))" ''
        fi
    }

    _tui_draw() {
        tput cup 0 0
        printf '%s┌%s┐%s\n' "$C_BOX" "$bar" "$C_RST"
        printf '%s│%s %s %s│%s\n' \
            "$C_BOX" "$C_TITLE" "$(_pad "$title" "$inner")" "$C_RST$C_BOX" "$C_RST"
        if [[ -n "$subtitle" ]]; then
            printf '%s│%s %s %s│%s\n' \
                "$C_BOX" "$C_SUB" "$(_pad "$subtitle" "$inner")" "$C_RST$C_BOX" "$C_RST"
        else
            printf '%s│%s│%s\n' "$C_BOX" "$(_pad "" "$((width - 2))")" "$C_RST"
        fi
        printf '%s├%s┤%s\n' "$C_BOX" "$bar" "$C_RST"

        # Helper: print an empty row (used for between-section whitespace).
        _blank_row() {
            printf '%s│%s│%s\n' "$C_BOX" "$(_pad "" "$((width - 2))")" "$C_RST"
        }

        local i prefix color head_text head_line dashes
        local rendered_any=0
        for ((i = 0; i < n; i++)); do
            if [[ "${labels[i]}" == "@header:"* ]]; then
                # Breathing room between sections — blank row before every
                # header except the first thing drawn.
                (( rendered_any )) && _blank_row

                # Dim dashed section header.
                #   "@header:session"  →  "── session ──────────..."
                #   "@header:"         →  "───────────────────────────" (plain rule)
                head_text="${labels[i]#@header:}"
                if [[ -z "$head_text" ]]; then
                    dashes="$(printf '─%.0s' $(seq 1 $inner))"
                    printf '%s│%s %s %s│%s\n' \
                        "$C_BOX" "$C_HINT" "$dashes" "$C_RST$C_BOX" "$C_RST"
                else
                    head_line="── ${head_text} "
                    local dash_count=$(( inner - ${#head_line} ))
                    (( dash_count < 0 )) && dash_count=0
                    dashes=""
                    (( dash_count > 0 )) && dashes="$(printf '─%.0s' $(seq 1 $dash_count))"
                    printf '%s│%s %s%s %s│%s\n' \
                        "$C_BOX" "$C_HINT" "$head_line" "$dashes" "$C_RST$C_BOX" "$C_RST"
                fi
                rendered_any=1
                continue
            fi
            if (( i == sel )); then
                prefix="▸ "
                color="$C_SEL"
            else
                prefix="  "
                color="$C_ITEM"
            fi
            printf '%s│%s %s%s %s│%s\n' \
                "$C_BOX" "$color" "$prefix" \
                "$(_pad "${labels[i]}" "$((inner - 2))")" \
                "$C_RST$C_BOX" "$C_RST"
            rendered_any=1
        done

        printf '%s│%s│%s\n' "$C_BOX" "$(_pad "" "$((width - 2))")" "$C_RST"
        printf '%s├%s┤%s\n' "$C_BOX" "$bar" "$C_RST"

        # Help area — exactly $help_h lines, padded with blanks
        local wrapped=()
        mapfile -t wrapped < <(printf '%s\n' "${helps[sel]}" | _tui_wrap "$inner")
        local j line
        for ((j = 0; j < help_h; j++)); do
            line="${wrapped[j]:-}"
            printf '%s│%s %s %s│%s\n' \
                "$C_BOX" "$C_HELP" "$(_pad "$line" "$inner")" "$C_RST$C_BOX" "$C_RST"
        done

        printf '%s└%s┘%s\n' "$C_BOX" "$bar" "$C_RST"
        printf '\n'
        printf '  %sSteam Deck:  D-pad ↑↓ (move)  ·  A (select)  ·  B (back)%s\n' \
            "$C_HINT" "$C_RST"
        printf '\n'
        printf '  %sKeyboard:    ↑↓ (move)  ·  Enter / Space (select)  ·%s\n' \
            "$C_HINT" "$C_RST"
        printf '               %sEsc / Backspace (back)%s' \
            "$C_HINT" "$C_RST"
        tput ed  # erase to end of screen — wipes leftovers from larger prior menus
    }

    clear
    tput civis 2>/dev/null || true

    # Extract the leading numeric prefix ("1", "12", …) from labels[sel].
    # Returns 0 (the 1-based position within items) if no number is found.
    _reply_from_label() {
        local lbl="${labels[sel]}"
        if [[ "$lbl" =~ ^([0-9]+) ]]; then
            REPLY="${BASH_REMATCH[1]}"
        else
            REPLY=$((sel_pos + 1))
        fi
    }

    local k k2
    while true; do
        _tui_draw
        if ! IFS= read -rsn1 k; then
            # EOF on stdin (e.g., script piped input). Treat as cancel.
            tput cnorm 2>/dev/null || true
            clear
            return 1
        fi
        case "$k" in
            $'\e')
                IFS= read -rsn2 -t 0.05 k2 || k2=""
                case "$k2" in
                    '[A')   # up arrow — previous selectable item, wrapping
                        sel_pos=$(( (sel_pos - 1 + item_count) % item_count ))
                        sel=${items[sel_pos]}
                        ;;
                    '[B')   # down arrow — next selectable item, wrapping
                        sel_pos=$(( (sel_pos + 1) % item_count ))
                        sel=${items[sel_pos]}
                        ;;
                    '')     # bare Esc — only this exits
                        tput cnorm 2>/dev/null || true
                        clear
                        return 1
                        ;;
                    # Any other escape (left/right arrow, F-keys, Home/End,
                    # Page Up/Down, …) — silently ignore.
                esac
                ;;
            ''|$'\n'|$'\r'|' ')  # Enter / Space — Steam Deck A sends Enter
                tput cnorm 2>/dev/null || true
                clear
                _reply_from_label
                return 0
                ;;
            [1-9])
                # Jump to the selectable item whose label begins with this digit.
                local p
                for ((p = 0; p < item_count; p++)); do
                    if [[ "${labels[items[p]]}" == "$k  "* ]]; then
                        sel_pos=$p
                        sel=${items[p]}
                        tput cnorm 2>/dev/null || true
                        clear
                        REPLY=$k
                        return 0
                    fi
                done
                ;;
            $'\x7f'|$'\b')  # Backspace — Steam Deck B button commonly maps here
                tput cnorm 2>/dev/null || true
                clear
                return 1
                ;;
            j)
                sel_pos=$(( (sel_pos + 1) % item_count ))
                sel=${items[sel_pos]}
                ;;
            k)
                sel_pos=$(( (sel_pos - 1 + item_count) % item_count ))
                sel=${items[sel_pos]}
                ;;
            # Anything else (letters, punctuation, stray keystrokes) — ignore.
            # Only Esc / Backspace / menu-Exit close the app.
        esac
    done
}

# =============================================================================
# Main menu
# =============================================================================

main_menu() {
    while true; do
        local current_mode boot_target mode_chip
        current_mode="$(detect_mode)"
        boot_target="$(get_boot_target)"
        if [[ "$current_mode" == "touch" ]]; then mode_chip="Touch"; else mode_chip="Desktop"; fi

        tui_menu \
            " TOGLIT  ·  v$VERSION " \
            " session: $mode_chip   ·   boot: $boot_target " \
            "@header:session" "" \
            "1  Touch Mode" \
            "Makes everything finger-sized: bigger fonts, larger icons, wider scrollbars, and chunky window buttons. Good for handheld or tablet use. Use Steam's on-screen keyboard (Steam+X) when you need to type." \
            "2  Desktop Mode" \
            "Rolls back to your original KDE settings. The snapshot was taken the first time you launched TOGLIT — no opinions imposed, just your setup." \
            "@header:boot" "" \
            "3  Boot Settings" \
            "Pick which mode the Deck always opens on power-on — Desktop or Gaming — with or without rebooting right now. The choice sticks until you change it here again." \
            "@header:system" "" \
            "4  Current Status" \
            "Quick read-only view of what TOGLIT owns: session mode, boot target, and whether a backup exists." \
            "5  Restore Backup" \
            "Same effect as Desktop Mode: rolls back to the first-launch snapshot. Kept as a separate entry in case Desktop Mode ever feels broken." \
            "6  Create Desktop Shortcut" \
            "Places (or re-places) the TOGLIT icon on your Desktop and in the application menu. Run it the first time to get the icon, or any time later if you accidentally delete it." \
            "@header:app" "" \
            "7  Exit" \
            "Close TOGLIT. Nothing changes on exit. Relaunch from the Desktop icon or by typing 'toglit' in a terminal." \
            || return 0

        case "$REPLY" in
            1)
                if [[ "$current_mode" == "touch" ]]; then
                    if whiptail --title " Already Active " --yesno \
                        "\n  Touch Mode is already active.\n  Re-apply settings anyway?" 9 44; then
                        toggle_touch
                    fi
                else
                    toggle_touch
                fi
                ;;
            2)
                if [[ "$current_mode" == "desktop" ]]; then
                    if whiptail --title " Already Active " --yesno \
                        "\n  Desktop Mode is already active.\n  Re-apply settings anyway?" 9 44; then
                        toggle_desktop
                    fi
                else
                    toggle_desktop
                fi
                ;;
            3) boot_menu ;;
            4) show_settings ;;
            5) restore_backup ;;
            6) repair_shortcut ;;
            7) return 0 ;;
        esac
    done
}

# =============================================================================
# Safety net: ensure plasmashell survives a script exit
# =============================================================================

cleanup() {
    tput cnorm 2>/dev/null || true
    # Only wait + respawn plasmashell if it's actually missing. In the common
    # case (user just navigated and quit), this is instant.
    if ! pgrep -x plasmashell >/dev/null 2>&1; then
        sleep 1.5
        if ! pgrep -x plasmashell >/dev/null 2>&1; then
            setsid plasmashell </dev/null &>/dev/null &
        fi
    fi
}
# =============================================================================
# Entry
# =============================================================================
#
# TOGLIT_SOURCE_ONLY=1 lets the test harness `source` this file to get every
# helper definition without side effects (no dep check, no migration, no
# splash, no backup, no menu). The harness sets it; nothing else does.

if [[ -n "${TOGLIT_SOURCE_ONLY:-}" ]]; then
    # When sourced, `return 0` exits this file; when executed, `return`
    # fails and `exit 0` runs. Not dead code — shellcheck can't see the
    # dual-invocation pattern.
    # shellcheck disable=SC2317
    return 0 2>/dev/null || exit 0
fi

trap cleanup EXIT

check_deps
migrate_state

print_splash animate
clear

# First-launch snapshot: captures the user's current KDE config (fonts, cursor,
# icons, animation, GTK, panel, virtual keyboard) BEFORE anything in this app
# can modify it. Idempotent — subsequent launches find the backup and skip.
# Desktop Mode / Restore Backup both roll back to this exact snapshot.
if ! create_backup; then
    echo >&2 "toglit: warning — couldn't create backup at $BACKUP_DIR"
    echo >&2 "toglit: Desktop Mode / Restore Backup won't work until this is fixed."
    echo >&2 "toglit: check permissions on ~/.config, and free disk space."
    echo >&2
fi

# SteamOS already ships its own on-screen keyboard (Steam+X). Scrub any
# qt6-virtualkeyboard env drop-ins from this or prior versions on every
# launch so the Qt variant stays off for good.
force_disable_vkbd

main_menu
