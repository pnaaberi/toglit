#!/usr/bin/env bash
# toglit — mode switching for Steam Deck Desktop
# https://github.com/pnaaberi/toglit
#
# Toggles KDE Plasma between Touch Mode (finger-friendly) and Desktop Mode,
# and controls which session SteamOS autologins into on boot.

set -euo pipefail

# UTF-8 locale so Bash's ${#string} counts characters (not bytes), which we
# rely on for aligning the TUI around em-dashes, middle-dots, box drawing, etc.
export LC_ALL="${LC_ALL:-${LANG:-C.UTF-8}}"

VERSION="1.2.0"

# =============================================================================
# ASCII splash
# =============================================================================

print_splash() {
    # $1 = "animate" (default) for a row-by-row reveal, "static" for instant.
    local mode="${1:-animate}"
    local step=0.14      # delay between each ASCII row (reveal)
    local pause=0.30     # pause between art and slogan
    local linger=5       # hold the full splash on screen before main menu
    if [[ "$mode" == "static" ]]; then
        step=0; pause=0; linger=0
    fi

    # ANSI — bold cyan for the art, bold bright cyan for the hook, dim for tag.
    local C_ART=$'\e[1;36m'
    local C_HOOK=$'\e[1;96m'
    local C_TAG=$'\e[2;37m'
    local C_RST=$'\e[0m'

    # Logo: figlet font "Pagga" — half-block + shaded dither glyphs.
    local rows=(
        "           ░▀█▀░█▀█░█▀▀░█░░░▀█▀░▀█▀"
        "           ░░█░░█░█░█░█░█░░░░█░░░█░"
        "           ░░▀░░▀▀▀░▀▀▀░▀▀▀░▀▀▀░░▀░"
    )

    # Skip support: each "sleep" is actually a `read -t` — any keypress during
    # the splash latches `skipped=1`, and every subsequent wait returns
    # immediately so the main menu appears right away.
    local skipped=0
    _hold() {
        local t="$1"
        (( skipped )) && return 0
        [[ "$t" == 0 ]] && return 0
        if read -rsn1 -t "$t" _skip_key 2>/dev/null; then
            skipped=1
        fi
        return 0
    }

    printf '\n\n'
    local r
    for r in "${rows[@]}"; do
        printf '%s%s%s\n' "$C_ART" "$r" "$C_RST"
        _hold "$step"
    done
    printf '\n'
    _hold "$pause"
    printf '     %sToggle it.%s  %sTouch · Desktop · Reboot.%s\n' \
        "$C_HOOK" "$C_RST" "$C_TAG" "$C_RST"
    printf '         %sfor Steam Deck · SteamOS Desktop Mode%s\n' \
        "$C_TAG" "$C_RST"
    printf '                      %sv%s%s\n\n' "$C_TAG" "$VERSION" "$C_RST"
    if [[ "$mode" != "static" ]]; then
        printf '                %s[ any key to skip ]%s\n' "$C_TAG" "$C_RST"
    fi
    _hold "$linger"
    return 0
}

# =============================================================================
# Shortcut (re)installer — baked-in so users who delete the Desktop icon can
# restore it without reaching for the installer script.
# =============================================================================

install_shortcut() {
    local script_path apps_dir desktop_dir tmpl icon_path
    # Resolve to an absolute path that survives PATH lookup + symlinks.
    # Cover three launch modes: `toglit` (via ~/.local/bin symlink),
    # `./toglit` (relative), `/abs/path/toglit` (absolute).
    if [[ "$0" == /* ]]; then
        script_path="$(readlink -f "$0" 2>/dev/null || echo "$0")"
    else
        local found
        found="$(command -v "$0" 2>/dev/null)"
        script_path="$(readlink -f "$found" 2>/dev/null || readlink -f "$0" 2>/dev/null || echo "$0")"
    fi
    apps_dir="$HOME/.local/share/applications"
    desktop_dir="$HOME/Desktop"
    mkdir -p "$apps_dir" "$desktop_dir" 2>/dev/null || return 1

    # Resolve an absolute icon path — Icon=toglit (bare theme lookup) is
    # brittle when the hicolor cache is stale. Prefer the installed copy,
    # fall back to the in-repo SVG, last-ditch the theme name.
    local candidates=(
        "$HOME/.local/share/icons/hicolor/scalable/apps/toglit.svg"
        "$(dirname -- "$script_path")/icons/toglit.svg"
    )
    local cand
    icon_path="toglit"
    for cand in "${candidates[@]}"; do
        if [[ -f "$cand" ]]; then
            icon_path="$cand"
            break
        fi
    done

    tmpl="[Desktop Entry]
Type=Application
Categories=Utility;System;
Comment=Mode + boot switcher designed for Steam Deck's SteamOS Desktop Mode
Exec=$script_path
Icon=$icon_path
Keywords=touch;toggle;mode;reboot;desktop;steamdeck;steamos;toglit;
Name=TOGLIT
Terminal=true
"
    printf '%s' "$tmpl" > "$apps_dir/toglit.desktop" || return 1
    printf '%s' "$tmpl" > "$desktop_dir/toglit.desktop" || return 1
    chmod +x "$apps_dir/toglit.desktop" "$desktop_dir/toglit.desktop" 2>/dev/null || true
    gio set -t string "$desktop_dir/toglit.desktop" metadata::trusted true 2>/dev/null || true
    return 0
}

# =============================================================================
# CLI flags (must run before anything else — allows `toglit --version` on systems
# missing dependencies, and helps scripted diagnostics)
# =============================================================================

case "${1:-}" in
    --version|-v)
        echo "toglit $VERSION"
        exit 0
        ;;
    --splash)
        print_splash static
        exit 0
        ;;
    --create-shortcut|--install-shortcut)
        # --install-shortcut kept as an alias for anyone who learned that flag
        if install_shortcut; then
            echo "✓ TOGLIT shortcut created at ~/Desktop/toglit.desktop"
            exit 0
        else
            echo "✗ Failed to create shortcut" >&2
            exit 1
        fi
        ;;
    --help|-h)
        cat <<EOF
toglit $VERSION
Designed for the Steam Deck's SteamOS Desktop Mode (KDE Plasma 6 / Qt 6).
Not intended for any other environment.

Usage: toglit [OPTION]

  (no option)        Launch the interactive menu
  --splash           Print the TOGLIT banner and exit
  --create-shortcut  Place the TOGLIT icon on the Desktop + app menu
  --version          Print version and exit
  --help             Show this help and exit
EOF
        exit 0
        ;;
esac

# =============================================================================
# Breeze Dark theme for whiptail
# =============================================================================

export NEWT_COLORS='
root=cyan,black
window=white,black
border=cyan,black
shadow=black,black
title=white,black
button=black,cyan
actbutton=black,white
compactbutton=cyan,black
checkbox=white,black
actcheckbox=black,cyan
listbox=white,black
actlistbox=black,cyan
sellistbox=cyan,black
actsellistbox=black,cyan
textbox=white,black
acttextbox=cyan,black
