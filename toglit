# =============================================================================
# Paths
# =============================================================================

STATE_DIR="$HOME/.config/toglit"
# Migration chain — older state dirs get moved to STATE_DIR on first run.
LEGACY_DIRS=("$HOME/.config/flux" "$HOME/.config/touch-toggle")
STATE_FILE="$STATE_DIR/mode"
BACKUP_DIR="$STATE_DIR/backup"

KDEGLOBALS="$HOME/.config/kdeglobals"
KWINRC="$HOME/.config/kwinrc"
OXYGENRC="$HOME/.config/oxygenrc"
BREEZERC="$HOME/.config/breezerc"
DOLPHINRC="$HOME/.config/dolphinrc"
KCMINPUTRC="$HOME/.config/kcminputrc"
GTK3_SETTINGS="$HOME/.config/gtk-3.0/settings.ini"
GTK4_SETTINGS="$HOME/.config/gtk-4.0/settings.ini"
PLASMASHELLRC="$HOME/.config/plasmashellrc"
MALIIT_ENV="$HOME/.config/plasma-workspace/env/toglit-im.sh"
LEGACY_MALIIT_ENVS=(
    "$HOME/.config/plasma-workspace/env/flux-im.sh"
    "$HOME/.config/plasma-workspace/env/touch-toggle-im.sh"
)

SDDM_AUTOLOGIN_CONF="/etc/sddm.conf.d/zz-steamos-autologin.conf"
# SDDM drops shipped by SteamOS/KDE that each carry their own `User=deck` under
# [Autologin]. SDDM merges every .conf.d file in alphabetical order, so to
# actually stop the autologin we must comment `User=` in BOTH — otherwise the
# surviving one keeps logging `deck` in automatically.
SDDM_SYSTEM_CONFS=(
    "/etc/sddm.conf.d/steamos.conf"
    "/etc/sddm.conf.d/kde_settings.conf"
)

# Font strings (10-field format; 16-field triggers stack-smash in Qt 6.8)
TOUCH_FONT="Hack,14,-1,5,400,0,0,0,0,0"

# =============================================================================
# qdbus resolver — Plasma 6 needs the Qt6 variant
# =============================================================================

# If neither binary is installed, QDBUS stays empty — check_deps (below)
# catches that and exits with a clear message instead of soft-failing later.
QDBUS="$(command -v qdbus6 2>/dev/null || command -v qdbus 2>/dev/null || true)"

# =============================================================================
# Dependency check
# =============================================================================

check_deps() {
    local missing=()
    local c
    for c in whiptail kreadconfig6 kwriteconfig6 \
             steamos-session-select dbus-send xrdb pkexec systemctl \
             sed awk find grep cut dirname pgrep pkill passwd id; do
        command -v "$c" >/dev/null 2>&1 || missing+=("$c")
    done
    # qdbus is needed for plasmashell scripting; accept either the Plasma 6
    # binary (qdbus6) or the legacy name (qdbus). QDBUS resolver above picks
    # whichever exists.
    if ! command -v qdbus6 >/dev/null 2>&1 && ! command -v qdbus >/dev/null 2>&1; then
        missing+=("qdbus6 (or qdbus)")
    fi
    if (( ${#missing[@]} > 0 )); then
        echo >&2 "toglit: missing required commands: ${missing[*]}"
        echo >&2 "This tool is designed for stock SteamOS (Steam Deck, Plasma 6)."
        exit 1
    fi
}

# =============================================================================
# Safe-input helpers for the one privileged sed invocation (autologin toggle)
# =============================================================================

# Resolve the real login name via the password database (`id -un`), not
# `$USER` (which is env-controlled). Enforces a strict POSIX username shape
# (32 char cap, lowercase + digits + _ + -). Returns 1 on anything exotic —
# we refuse to touch /etc/sddm.conf.d unless we're certain what the user is.
_safe_login_user() {
    local u
    u="$(id -un 2>/dev/null)" || return 1
    [[ "$u" =~ ^[a-z_][a-z0-9_-]{0,31}$ ]] || return 1
    printf '%s' "$u"
}

# Regex-escape a string for POSIX ERE (`sed -E`). Escapes every character
# that carries meaning in a pattern, plus `/` so the string is safe to
# embed in `s/pattern/repl/` without delimiter collisions. Passes through
# only `[A-Za-z0-9_-]` literally — everything else gets a backslash.
_sed_regex_escape() {
    local s="$1" out="" i c
    for (( i=0; i<${#s}; i++ )); do
        c="${s:i:1}"
        case "$c" in
            [a-zA-Z0-9_-]) out+="$c" ;;
            *)             out+="\\$c" ;;
        esac
    done
    printf '%s' "$out"
}

# =============================================================================
# State migration (touch-toggle → toglit)
# =============================================================================

migrate_state() {
    # Walk the migration chain: first existing legacy dir wins (newer first).
    # Every step is soft-failing so a read-only / permission-denied $HOME
    # doesn't kill the script before the user sees any UI.
    local legacy
    for legacy in "${LEGACY_DIRS[@]}"; do
        if [[ -d "$legacy" && ! -d "$STATE_DIR" ]]; then
            mv "$legacy" "$STATE_DIR" 2>/dev/null || true
            break
        fi
    done
    mkdir -p "$STATE_DIR" 2>/dev/null || true
}

# =============================================================================
# Backup / restore
# =============================================================================

create_backup() {
    # Soft-failing: if any cp/mkdir fails (disk full, read-only fs,
    # permission denied), return non-zero so the caller can warn — don't
    # crash the whole script before the user even sees a menu.
    if [[ -d "$BACKUP_DIR" ]]; then
        return 0
    fi
    mkdir -p "$BACKUP_DIR" 2>/dev/null || return 1
    local files=(
        "$KDEGLOBALS"
        "$KWINRC"
        "$OXYGENRC"
        "$BREEZERC"
        "$DOLPHINRC"
        "$KCMINPUTRC"
        "$GTK3_SETTINGS"
        "$GTK4_SETTINGS"
        "$PLASMASHELLRC"
    )
    local f rel
    # Strip "$HOME/.config/" by offset (length of $HOME + 9 for "/.config/").
    # Parameter-expansion prefix stripping would treat $HOME as a glob
    # pattern and misbehave on exotic $HOME values containing [ * ? etc.
    local home_prefix_len=$(( ${#HOME} + 9 ))
    for f in "${files[@]}"; do
        if [[ -f "$f" ]]; then
            rel="${f:home_prefix_len}"
            mkdir -p "$BACKUP_DIR/$(dirname "$rel")" 2>/dev/null || return 1
            cp "$f" "$BACKUP_DIR/$rel" 2>/dev/null || return 1
        fi
    done
    return 0
}

normalize_kdeglobals_fonts() {
    # Rewrite any >10-field font strings to 10-field format to avoid the Qt 6.8
    # stack-smash bug. Pointsize is validated as a plain positive integer
    # before we write it back — we refuse to launder an exotic / corrupted
    # kdeglobals through kwriteconfig6 unchanged.
    local font_keys=(font fixed toolBarFont menuFont smallestReadableFont)
    local key val count family pointsize
    for key in "${font_keys[@]}"; do
        val="$(kreadconfig6 --file kdeglobals --group General --key "$key" 2>/dev/null || true)"
        [[ -z "$val" ]] && continue
        count=$(awk -F, '{print NF}' <<<"$val")
        if (( count > 10 )); then
            family="$(cut -d, -f1 <<<"$val")"
            pointsize="$(cut -d, -f2 <<<"$val")"
            [[ "$pointsize" =~ ^[0-9]+$ ]] || continue
            kwriteconfig6 --file kdeglobals --group General --key "$key" \
                "${family},${pointsize},-1,5,400,0,0,0,0,0"
        fi
    done
    val="$(kreadconfig6 --file kdeglobals --group WM --key activeFont 2>/dev/null || true)"
    if [[ -n "$val" ]]; then
        count=$(awk -F, '{print NF}' <<<"$val")
        if (( count > 10 )); then
            family="$(cut -d, -f1 <<<"$val")"
            pointsize="$(cut -d, -f2 <<<"$val")"
            [[ "$pointsize" =~ ^[0-9]+$ ]] || return 0
            kwriteconfig6 --file kdeglobals --group WM --key activeFont \
                "${family},${pointsize},-1,5,400,0,0,0,0,0"
        fi
    fi
}

_restore_backup_files() {
    # Copy every backed-up file back to ~/.config/, normalise fonts to the
    # 10-field format (dodges Qt 6.8's stack-smash bug), and clear the Qt
    # virtual-keyboard env drop-in. Returns 1 if no backup exists.
    [[ -d "$BACKUP_DIR" ]] || return 1

    local f rel dest
    while IFS= read -r -d '' f; do
        # Quote the pattern. Unquoted `${f#$BACKUP_DIR/}` would treat
        # $BACKUP_DIR as a glob pattern, so exotic $HOME values containing
        # `[`, `*`, `?` could mis-strip and write files outside ~/.config/.
        rel="${f#"$BACKUP_DIR"/}"
        dest="$HOME/.config/$rel"
        mkdir -p "$(dirname "$dest")"
        # If a symlink was planted at $dest (e.g. pointing at /etc/...),
        # `cp` would follow it and overwrite the target. Unlink first so
        # we always write a regular file at the intended path.
        [[ -L "$dest" ]] && rm -f "$dest"
        cp "$f" "$dest"
    done < <(find "$BACKUP_DIR" -type f -print0)

    normalize_kdeglobals_fonts
    force_disable_vkbd
    return 0
}

_notify_kde_live() {
    # Push config-file changes into the running Plasma session without
    # restarting plasmashell. Preserves any inhibitor locks plasmashell holds
    # (e.g. a manual "prevent screen sleep" the user toggled on).
    dbus-send --type=signal /KGlobalSettings org.kde.KGlobalSettings.notifyChange \
        int32:0 int32:0 2>/dev/null || true
    dbus-send --type=signal /KIconLoader org.kde.KIconLoader.iconChanged \
        int32:0 2>/dev/null || true
    sleep 1
    "$QDBUS" org.kde.KWin /KWin org.kde.KWin.reconfigure 2>/dev/null || true
}

restore_backup() {
    if ! _restore_backup_files; then
        whiptail --title " Error " --msgbox "\n  No backup found." 7 34
        return 1
    fi
    _notify_kde_live
    echo "desktop" > "$STATE_FILE"
    whiptail --title " Restored " --msgbox \
        "\n  Your original settings are back.\n  (Snapshot from your first Touch Mode toggle.)\n\n  Panel height + GTK apps update on next login." \
        11 54
}

# =============================================================================
# Detect current in-session mode
# =============================================================================

detect_mode() {
    if [[ -f "$STATE_FILE" ]]; then
        cat "$STATE_FILE"
        return
    fi
    local current_font pointsize
    current_font="$(kreadconfig6 --file kdeglobals --group General --key font 2>/dev/null || true)"
    pointsize="$(awk -F, '{print $2}' <<<"$current_font")"
    if [[ "$pointsize" == "14" ]]; then
        echo "touch"
    else
        echo "desktop"
    fi
}

# =============================================================================
# Apply — Touch Mode
# =============================================================================

apply_touch_fonts() {
    local font_keys=(font fixed toolBarFont menuFont smallestReadableFont)
    local key
    for key in "${font_keys[@]}"; do
        kwriteconfig6 --file kdeglobals --group General --key "$key" "$TOUCH_FONT"
    done
    kwriteconfig6 --file kdeglobals --group WM --key activeFont "$TOUCH_FONT"
}

apply_touch_gtk() {
    local ini
    for ini in "$GTK3_SETTINGS" "$GTK4_SETTINGS"; do
        if [[ -f "$ini" ]]; then
            sed -i 's/^gtk-font-name=.*/gtk-font-name=Hack 14/' "$ini"
        fi
    done
}

apply_cursor_env() {
    # Shared helper: re-publish the user's current cursor theme/size to X,
    # D-Bus, and ~/.icons/default so running apps pick it up without a reboot.
    # Never overrides the user's choice.
    local current_theme current_size
    current_theme="$(kreadconfig6 --file kcminputrc --group Mouse --key cursorTheme 2>/dev/null || true)"
    current_size="$(kreadconfig6 --file kcminputrc --group Mouse --key cursorSize 2>/dev/null || true)"
    [[ -z "$current_size" ]] && current_size="24"

    if [[ -n "$current_theme" ]]; then
        { echo "Xcursor.theme: $current_theme"; echo "Xcursor.size: $current_size"; } | xrdb -merge 2>/dev/null || true
        export XCURSOR_THEME="$current_theme" XCURSOR_SIZE="$current_size"
        dbus-update-activation-environment --systemd XCURSOR_THEME XCURSOR_SIZE 2>/dev/null || true
        mkdir -p "$HOME/.icons/default"
        printf '[Icon Theme]\nInherits=%s\n' "$current_theme" > "$HOME/.icons/default/index.theme"
    fi
}

apply_touch_cursor() { apply_cursor_env; }

apply_touch_icons() {
    kwriteconfig6 --file kdeglobals --group ToolbarIcons     --key Size 32
    kwriteconfig6 --file kdeglobals --group MainToolbarIcons --key Size 32
    kwriteconfig6 --file kdeglobals --group PanelIcons       --key Size 48
    kwriteconfig6 --file kdeglobals --group DialogIcons      --key Size 48
    kwriteconfig6 --file kdeglobals --group SmallIcons       --key Size 22
    kwriteconfig6 --file kdeglobals --group DesktopIcons     --key Size 64
}

apply_touch_window_decorations() {
    kwriteconfig6 --file oxygenrc --group Windeco --key ButtonSize ButtonVeryLarge
}

# plasmashell.evaluateScript wrappers. Both take a single integer, validated
# to a narrow range, before any string concatenation. This bounds the only
# thing we interpolate into a JavaScript blob to "integers we chose
# ourselves", so the scripting surface stays auditable as the callers grow.
_plasma_set_panel_height() {
    local h="$1"
    [[ "$h" =~ ^[0-9]+$ ]] && (( h >= 16 && h <= 256 )) || return 1
    "$QDBUS" org.kde.plasmashell /PlasmaShell org.kde.PlasmaShell.evaluateScript \
        "var ps=panels(); for (var i=0;i<ps.length;i++) ps[i].height=$h;" \
        2>/dev/null || true
}

_plasma_set_desktop_icon_size() {
    # iconSize indexes are Plasma's "size categories" (0..6). Narrowly clamped.
    local s="$1"
    [[ "$s" =~ ^[0-6]$ ]] || return 1
    "$QDBUS" org.kde.plasmashell /PlasmaShell org.kde.PlasmaShell.evaluateScript \
        "var ds=desktops(); for (var i=0;i<ds.length;i++){var d=ds[i]; d.currentConfigGroup=['General']; d.writeConfig('iconSize', $s);}" \
        2>/dev/null || true
}

apply_touch_panel()         { _plasma_set_panel_height 64; }
apply_touch_desktop_icons() { _plasma_set_desktop_icon_size 3; }

apply_touch_dolphin() {
    kwriteconfig6 --file dolphinrc --group IconsMode   --key PreviewSize 64
    kwriteconfig6 --file dolphinrc --group IconsMode   --key IconSize    64
    kwriteconfig6 --file dolphinrc --group CompactMode --key PreviewSize 64
    kwriteconfig6 --file dolphinrc --group CompactMode --key IconSize    64
}

apply_touch_animation() {
    kwriteconfig6 --file kdeglobals --group KDE     --key AnimationDurationFactor 0.5
    kwriteconfig6 --file kdeglobals --group General --key XftHintStyle            hintslight
    printf "Xft.hintstyle:\thintslight\n" | xrdb -merge - 2>/dev/null || true
}

apply_touch_single_click() {
    kwriteconfig6 --file kdeglobals --group KDE --key SingleClick true
}

apply_touch_scrollbar() {
    kwriteconfig6 --file breezerc --group Style --key ScrollBarWidth 20
}

# =============================================================================
# Force-disable Qt virtual keyboard
#
# SteamOS already ships an on-screen keyboard (Steam+X overlay), so
# qt6-virtualkeyboard is redundant. We proactively delete any env drop-in
# from this or prior TOGLIT / touch-toggle versions and clear QT_IM_MODULE
# from the running D-Bus activation environment, so Qt apps stop popping a
# keyboard on text-field focus without requiring a logout.
# =============================================================================

force_disable_vkbd() {
    rm -f "$MALIIT_ENV" "${LEGACY_MALIIT_ENVS[@]}" 2>/dev/null || true
    dbus-update-activation-environment --systemd QT_IM_MODULE= 2>/dev/null || true
    pkill -f maliit-server 2>/dev/null || true
}

# =============================================================================
# Desktop Mode — live plasmashell resets
# =============================================================================
#
# The config-file side of "Desktop Mode" is handled by copying the backup
# back (see _restore_backup_files). These two helpers only deal with the
# running plasmashell: its in-memory panel height and desktop icon size are
# not re-read from plasmashellrc automatically, so we nudge them via the
# plasmashell scripting interface. No plasmashell restart needed — so any
# inhibitor locks plasmashell is holding (e.g. a manual "prevent screen
# sleep" toggle) survive.

apply_desktop_panel()         { _plasma_set_panel_height 40; }
apply_desktop_desktop_icons() { _plasma_set_desktop_icon_size 2; }

# =============================================================================
# Toggles
# =============================================================================

toggle_touch() {
    # Snapshot the pristine state on the first toggle (of either direction),
    # so Desktop Mode / Restore Backup can put things back exactly.
    create_backup

    echo "Applying Touch Mode settings..."
    apply_touch_fonts
    apply_touch_gtk
    apply_touch_cursor
    apply_touch_icons
    apply_touch_window_decorations
    apply_touch_dolphin
    apply_touch_animation
    apply_touch_single_click
    apply_touch_scrollbar

    _notify_kde_live
    sleep 1

    # Live panel + desktop-icon size via plasmashell scripting — applies now,
    # no restart of plasmashell needed (preserves the user's sleep-inhibitor
    # lock etc.).
    apply_touch_panel
    sleep 0.5
    apply_touch_desktop_icons

    echo "touch" > "$STATE_FILE"

    whiptail --title " Touch Mode Active " --msgbox \
        "\n  Fonts ............. 14pt\n  Cursor ............ preserved\n  Panel ............. 64px\n  Icons ............. enlarged\n  Window buttons .... very large\n  Scrollbars ........ 20px\n  Single-click ...... on\n\n  GTK apps need restart for changes." \
        16 50
}

toggle_desktop() {
    # "Desktop Mode" = literally rolling back to the pre-Touch snapshot.
    # If no backup exists yet, take one now (captures the user's true
    # untouched state) and then the restore is a no-op copy over itself.
    create_backup

    if ! _restore_backup_files; then
        whiptail --title " Error " --msgbox \
            "\n  Could not create or read backup.\n  Check permissions on ~/.config/toglit/." \
            9 50
        return 1
    fi

    _notify_kde_live
    sleep 1

    # Live panel + desktop-icon reset via plasmashell scripting. Uses sensible
    # Plasma defaults (height 40, icon index 2). If the user had a custom
    # panel height pre-Touch, it will match exactly after the next login
    # (plasmashellrc from the backup has been restored).
    apply_desktop_panel
    sleep 0.5
    apply_desktop_desktop_icons

    echo "desktop" > "$STATE_FILE"

    whiptail --title " Desktop Mode Active " --msgbox \
        "\n  Your settings are back to how they were\n  before your first Touch Mode toggle.\n\n  Panel + GTK apps update fully on next login." \
        11 52
}

# =============================================================================
# Boot target (SDDM autologin)
# =============================================================================

get_boot_target() {
    local sess=""
    if [[ -r "$SDDM_AUTOLOGIN_CONF" ]]; then
        sess="$(awk -F= '/^Session[[:space:]]*=/{print $2; exit}' "$SDDM_AUTOLOGIN_CONF" 2>/dev/null || true)"
        sess="${sess// /}"
    fi
    case "$sess" in
        gamescope-wayland.desktop)           echo "gaming" ;;
        plasma.desktop|plasmax11.desktop)    echo "desktop" ;;
        plasma-steamos-oneshot.desktop|\
        plasma-steamos-wayland-oneshot.desktop) echo "gaming*" ;;
        "") echo "unset" ;;
        *) echo "custom" ;;
    esac
}

set_boot_target() {
    # target ∈ {desktop, desktop-once, gaming}
    #   desktop       — persistent, writes plasma.desktop
    #   desktop-once  — one-shot, writes plasma-steamos-wayland-oneshot.desktop
    #                   On next login /usr/bin/startplasma-steamos-oneshot
    #                   auto-reverts the autologin back to gamescope, so the
    #                   BOOT AFTER returns to Gaming with no work from the user.
    #   gaming        — persistent, writes gamescope-wayland.desktop
    local target="$1"
    local arg
    case "$target" in
        desktop)      arg="plasma-wayland-persistent" ;;
        desktop-once) arg="plasma-wayland" ;;
        gaming)       arg="gamescope" ;;
        *) return 1 ;;
    esac
    # --no-restart: keep our session alive; we'll reboot ourselves if asked
    steamos-session-select "$arg" --no-restart
}

# Write the persistent default, then re-read /etc/sddm.conf.d/zz-steamos-autologin.conf
# and tell the user what actually landed. If something else (Steam's "Return to
# Gaming" hook, the desktop Gaming.desktop shortcut, a one-shot session wrapper)
# overwrites our write in a race, the mismatch dialog surfaces it immediately
# instead of the user finding out only after a reboot.
_commit_default() {
    local target="$1" human
    case "$target" in
        desktop) human="Desktop" ;;
        gaming)  human="Gaming" ;;
        *) return 1 ;;
    esac

    if ! set_boot_target "$target"; then
        whiptail --title " Error " --msgbox \
            "\n  Failed to write the autologin config.\n  (Was the pkexec prompt cancelled?)" 9 52
        return 1
    fi

    local actual
    actual="$(get_boot_target)"

    if [[ "$actual" == "$target" ]]; then
        whiptail --title " Saved ✓ " --msgbox \
            "\n  Default boot target: $human\n  (verified on disk — zz-steamos-autologin.conf)\n\n  Takes effect on next reboot." \
            11 56
    else
        whiptail --title " Mismatch " --msgbox \
            "\n  We asked for: $human\n  On-disk now reads: $actual\n\n  Something else overwrote our write.\n  Likely culprits:\n    - Steam's 'Return to Gaming Mode' hook\n    - the Gaming.desktop icon on your Desktop\n    - a Plasma one-shot session wrapper\n\n  For a guaranteed one-time boot to Desktop,\n  pick option 1 instead — it reboots immediately\n  so nothing else has time to interfere." \
            19 58
    fi
}

restart_to() {
    local target="$1"
    local title body
    case "$target" in
        desktop-once)
            title=" Reboot to Desktop · just this once "
            body="\n  Save your work — this will reboot now.\n\n  Next boot opens Plasma Desktop.\n  The boot after that returns to your default.\n\n  Your default boot target is NOT changed.\n\n  Continue?"
            ;;
        gaming)
            title=" Reboot to Gaming · just this once "
            body="\n  Save your work — this will reboot now.\n\n  Next boot opens Steam's Gaming UI.\n\n  This also sets Gaming as your default\n  boot target if it wasn't already.\n\n  Continue?"
            ;;
        *) return 1 ;;
    esac

    if ! whiptail --title "$title" --yesno "$body" 14 54; then
        return 0
    fi

    if ! set_boot_target "$target"; then
        whiptail --title " Error " --msgbox \
            "\n  Failed to set boot target.\n  (Was the pkexec prompt cancelled?)" 9 48
        return 1
    fi
    sleep 0.5
    systemctl reboot
}

_password_status() {
    # Returns one of: "set" | "none" | "unknown" on stdout.
    #   set     — passwd -S reports a usable password (code "P").
    #   none    — passwd -S reports no password or account locked ("NP" / "L").
    #             This is the *confirmed* unsafe case — caller must BLOCK, not warn.
    #   unknown — passwd -S unavailable / refused / unrecognised status code,
    #             or we couldn't resolve a safe login name.
    local user status code
    if ! user="$(_safe_login_user)"; then
        echo "unknown"
        return
    fi
    if status="$(passwd -S "$user" 2>/dev/null)"; then
        # passwd -S output: <user> <P|NP|L> <date> <min> <max> <warn> <inactive>
        code="$(awk '{print $2}' <<<"$status")"
        case "$code" in
            P)    echo "set";  return ;;
            NP|L) echo "none"; return ;;
        esac
    fi
    echo "unknown"
}

_blink_banner() {
    # Shared blinking terminal banner. $1 = heading (shown in bold red);
    # $2..$N = body lines (printed one per line, indented). Waits for a
    # keystroke before returning so the user actually sees it before the
    # whiptail dialog repaints the screen.
    #
    # Many modern terminals (incl. some Konsole profiles) disable ANSI
    # blink for sanity. The bold red + caps carry the message regardless —
    # the blink is icing.
    clear
    local BLINK=$'\e[1;5;97;41m'   # bold · blink · white on red
    local RED=$'\e[1;31m'
    local BOLD=$'\e[1m'
    local DIM=$'\e[2;37m'
    local RST=$'\e[0m'

    local heading="$1"; shift

    printf '\n\n'
    printf '   %s  ! ! !   W A R N I N G   ! ! !  %s\n' "$BLINK" "$RST"
    printf '\n'
    printf '   %s%s%s\n' "$RED" "$heading" "$RST"
    local line
    for line in "$@"; do
        if [[ -z "$line" ]]; then
            printf '\n'
        else
            printf '   %s\n' "$line"
        fi
    done
    printf '\n'
    printf '   %s(some terminals disable blink — the warning is still real)%s\n' "$DIM" "$RST"
    printf '\n\n'
    printf '         %s[ press any key to continue ]%s\n' "$BOLD" "$RST"
    read -rsn1 _ </dev/tty 2>/dev/null || read -rsn1 _ || true
}

_block_no_password() {
    # Confirmed: user has no login password. Hard block — show a msgbox
    # with instructions to set a password, and return. No yesno path.
    local user
    user="$(_safe_login_user || echo 'your')"
    _blink_banner \
        "THE \"$user\" USER HAS NO LOGIN PASSWORD." \
        "" \
        "Disabling autologin would lock you out of the" \
        "Deck — there would be no way to log in at the" \
        "login screen." \
        "" \
        "SET A PASSWORD FIRST:" \
        "  open Konsole and run:    passwd" \
        "" \
        "Then come back and try this again."

    whiptail --title " CANNOT DISABLE AUTOLOGIN " --msgbox \
        "\n  THE '$user' USER HAS NO LOGIN PASSWORD.\n\n  Disabling autologin would lock you out of\n  the Deck — there would be no way to log in\n  at the login screen.\n\n  Set a password first:\n    open Konsole, run:  passwd\n\n  Then come back and try this again." \
        16 54
}

_warn_password_unknown() {
    # Could not confirm password status (passwd -S refused or returned an
    # unrecognised code). Warn loudly, default to No, let the user override.
    local user
    user="$(_safe_login_user || echo 'your')"
    _blink_banner \
        "COULD NOT VERIFY \"$user\" HAS A LOGIN PASSWORD." \
        "" \
        "If there is no password, disabling autologin" \
        "will LOCK YOU OUT at the login screen." \
        "" \
        "Recommended: run 'passwd' in Konsole first" \
        "to make sure a password is set."

    whiptail --title " PASSWORD STATUS UNKNOWN " --defaultno --yesno \
        "\n  COULD NOT VERIFY WHETHER '$user' HAS\n  A LOGIN PASSWORD.\n\n  If not, disabling autologin will LOCK YOU\n  OUT at the login screen.\n\n  Proceed anyway?" \
        13 54
}

get_autologin_state() {
    # Scoped to the current user so TOGLIT never claims autologin is "on"
    # for a different account on multi-user systems.
    #
    # "on"  — at least one SDDM drop has an uncommented "User=<me>" line,
    #         so SDDM will skip the greeter and log us straight in.
    # "off" — no such line. SDDM either shows the greeter or auto-logs a
    #         different user — both count as "off" from our point of view.
    #
    # Field-compare via awk: the username is fed in as -v and compared to
    # the captured value as a literal string. No regex surface — a
    # username containing regex metachars can't bend the match.
    local user
    user="$(_safe_login_user)" || { echo "off"; return; }
    local f
    for f in "${SDDM_SYSTEM_CONFS[@]}"; do
        [[ -r "$f" ]] || continue
        if awk -v u="$user" '
            /^[[:space:]]*User[[:space:]]*=[[:space:]]*/ {
                val = $0
                sub(/^[[:space:]]*User[[:space:]]*=[[:space:]]*/, "", val)
                sub(/[[:space:]]+$/, "", val)
                if (val == u) { found = 1; exit }
            }
            END { exit !found }
        ' "$f" 2>/dev/null; then
            echo "on"
            return
        fi
    done
    echo "off"
}

toggle_autologin() {
    # Flips User= between commented and uncommented in every SDDM drop listed
    # in SDDM_SYSTEM_CONFS. Uses pkexec so the user gets a graphical auth
    # prompt — no sudo is cached by TOGLIT, and the edit is a single atomic
    # sed invocation elevated once.
    #
    # Safety: we NEVER interpolate the raw $USER into the sed pattern. Instead
    # we resolve the login via `id -un`, validate it matches a strict POSIX
    # username shape, then regex-escape it. A username containing metachars
    # cannot bend the pattern or the /s/a/b/ delimiters, and a missing/exotic
    # username aborts with a user-visible error — we will not run sed under
    # pkexec on a value we couldn't confirm.
    local user user_re
    if ! user="$(_safe_login_user)"; then
        whiptail --title " Error " --msgbox \
            "\n  Couldn't resolve a safe login name for your\n  user. Refusing to edit /etc/sddm.conf.d.\n\n  Set USER via a normal login (not a shell\n  override) and try again." \
            11 54
        return 1
    fi
    user_re="$(_sed_regex_escape "$user")"

    local current new title body
    current="$(get_autologin_state)"

    # About to DISABLE autologin? Check the user's login password:
    #   none    — CONFIRMED no password. Hard block (msgbox + return).
    #   unknown — can't tell. Warn with blink + --defaultno yesno.
    #   set     — safe to proceed; fall through to the normal confirm.
    if [[ "$current" == "on" ]]; then
        case "$(_password_status)" in
            none)
                _block_no_password
                return 0
                ;;
            unknown)
                if ! _warn_password_unknown; then
                    return 0
                fi
                ;;
        esac
    fi

    if [[ "$current" == "on" ]]; then
        # Physical-keyboard gate — SDDM's login screen has no virtual keyboard
        # and the Steam on-screen keyboard is completely unavailable there.
        # The user must confirm they have physical input before we proceed.
        if ! whiptail --title " ⚠  Physical keyboard required " \
                --defaultno --yesno \
                "\n  THE LOGIN SCREEN HAS NO ON-SCREEN KEYBOARD.\n\n  Once autologin is off, every boot shows a\n  login screen where you must type your\n  password to get in.\n\n  The Steam virtual keyboard does NOT work\n  there — neither does any other on-screen\n  keyboard. You will need a real, physical\n  keyboard plugged in (or paired via\n  Bluetooth) every time you power on.\n\n  If you don't have a physical keyboard\n  readily available, press No and leave\n  autologin enabled.\n\n  I have a physical keyboard and understand\n  I will need it at every login — continue?" \
                22 62; then
            return 0
        fi
        new="off"
        title=" Disable autologin? "
        body="\n  Currently: autologin ON — the Deck boots\n  straight into your default session.\n\n  After disabling, every power-on shows a\n  login screen. You'll pick the user, enter\n  your password, then pick the session.\n\n  Continue?"
    else
        new="on"
        title=" Enable autologin? "
        body="\n  Currently: autologin OFF — a login screen\n  shows up on every boot.\n\n  After enabling, the Deck will boot straight\n  into your default session (Desktop or Gaming,\n  whichever you've set) with no password prompt.\n\n  Continue?"
    fi

    if ! whiptail --title "$title" --yesno "$body" 18 56; then
        return 0
    fi

    local sed_expr
    if [[ "$new" == "off" ]]; then
        # Comment only OUR User= line — leave any other user's autologin
        # config alone on multi-user systems.
        sed_expr="s/^([[:space:]]*User[[:space:]]*=[[:space:]]*${user_re}[[:space:]]*)\$/#\\1/"
    else
        # Uncomment a commented #User= line we (or SDDM defaults) previously
        # wrote. If no such line exists, the edit is a no-op and the
        # mismatch dialog below fires.
        sed_expr="s/^#([[:space:]]*User[[:space:]]*=[[:space:]]*${user_re}[[:space:]]*)\$/\\1/"
    fi

    if ! pkexec /usr/bin/sed -i -E "$sed_expr" "${SDDM_SYSTEM_CONFS[@]}"; then
        whiptail --title " Error " --msgbox \
            "\n  Failed to update the login settings.\n  (Was the password prompt cancelled, or\n  did the system refuse the action?)" \
            11 50
        return 1
    fi

    local actual human
    actual="$(get_autologin_state)"
    if [[ "$actual" == "on" ]]; then human="ENABLED"; else human="DISABLED"; fi

    if [[ "$actual" == "$new" ]]; then
        whiptail --title " Saved ✓ " --msgbox \
            "\n  Autologin $human.\n  Takes effect on next reboot." \
            9 44
    else
        whiptail --title " Mismatch " --msgbox \
            "\n  We asked for: $new\n  On-disk now reads: $actual\n\n  The edit didn't stick. Check the files in\n  /etc/sddm.conf.d/ for stray User= lines." \
            12 54
    fi
}

boot_menu() {
    while true; do
        local current al autologin_label autologin_help
        current="$(get_boot_target)"
        al="$(get_autologin_state)"
        if [[ "$al" == "on" ]]; then
            autologin_label="5  Disable autologin (show login screen)"
            autologin_help="Currently ON — the Deck boots straight into your default session. Turning it OFF shows a login screen on every power-on: pick the user, type your password, pick the session. Useful if anyone else uses the Deck, or if you want to be explicit about which session starts."
        else
            autologin_label="5  Enable autologin (skip login screen)"
            autologin_help="Currently OFF — a login screen shows up on every boot. Turning it ON makes the Deck log 'deck' in automatically and launch your default session with no password prompt. The stock SteamOS behaviour."
        fi

        tui_menu \
            " Boot Settings " \
            " default: $current   ·   autologin: $al " \
            "@header:reboot now" "" \
            "1  Reboot to Desktop · just this once" \
            "Reboots right now and opens Plasma Desktop. The boot after that auto-returns to whatever your default is. Your default boot target is not changed — this is a one-time trip." \
            "2  Reboot to Gaming · just this once" \
            "Reboots right now and opens Steam's Gaming UI. Also sets Gaming as your default if it wasn't already — acts as a quick 'back to normal' button." \
            "@header:set persistent default" "" \
            "3  Default boot target: Desktop" \
            "Makes Plasma Desktop your permanent default. Every power-on from now on opens Desktop until you pick option 4. Nothing reboots now — change applies on next boot." \
            "4  Default boot target: Gaming" \
            "Makes Steam's Gaming UI your permanent default (the Deck's factory behaviour). Every power-on opens Gaming. Nothing reboots now — change applies on next boot." \
            "@header:autologin" "" \
            "$autologin_label" \
            "$autologin_help" \
            "@header:" "" \
            "6  Back" \
            "Return to the main TOGLIT menu without changing anything." \
            || return 0

        case "$REPLY" in
            1) restart_to desktop-once ;;
            2) restart_to gaming ;;
            3) _commit_default desktop ;;
            4) _commit_default gaming ;;
            5) toggle_autologin ;;
            6) return 0 ;;
        esac
    done
}

